{
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico",
        "languages": ["SimpChinese", "English"],
        "displayLanguageSelector": false,
        "customLanguageFiles": {
          "SimpChinese": "nsis/SimpChinese.nsh"
        },
        "installerHooks": "nsis/hooks.nsh"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": []
  },
  "productName": "JX3RaidManager",
  "mainBinaryName": "JX3RaidManager",
  "version": "2.1.18",
  "identifier": "com.jx3.raidmanager",
  "plugins": {
    "updater": {
      "pubkey": "",
      "windows": {
        "installMode": "basicUi"
      }
    }
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "fullscreen": false,
        "resizable": true,
        "title": "剑网三副本管家",
        "width": 1200,
        "height": 800,
        "decorations": true,
        "transparent": false,
        "useHttpsScheme": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https://icon.jx3box.com; connect-src ipc: http://ipc.localhost 'self' https://open.bigmodel.cn https://generativelanguage.googleapis.com https://node.jx3box.com; object-src 'none'; base-uri 'self'; frame-ancestors 'none'"
    }
  }
}
